# ─────────────────────────────────────────────────────────────────────────────
# JobTracker Backend — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL Database ────────────────────────────────────────────────────────────
# Used by docker-compose for local development
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=jobtracker
MYSQLUSER=your_db_user
MYSQLPASSWORD=your_db_password

# ── JWT Security ──────────────────────────────────────────────────────────────
# Must be at least 32 characters long for HS256
JWT_SECRET=replace-this-with-a-strong-random-secret-min-32-chars

# ── Spring Boot Profile ───────────────────────────────────────────────────────
# dev  → H2 in-memory database (no MySQL needed)
# prod → MySQL (requires all MYSQL* vars above)
SPRING_PROFILES_ACTIVE=prod

# ── Server Port ───────────────────────────────────────────────────────────────
PORT=8080
