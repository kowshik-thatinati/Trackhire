# ─────────────────────────────────────────────────────────────────────────────
# JobTracker Frontend — Environment Variables
# Copy this file to .env.local for local development.
#   cp .env.example .env.local
#
# For production (Vercel), set VITE_API_URL in:
#   - Vercel project dashboard → Settings → Environment Variables, OR
#   - GitHub secret VITE_API_URL (used by the CI/CD pipeline)
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL
# Local development:
VITE_API_URL=http://localhost:8080

# Production (Railway):
# VITE_API_URL=https://your-service.up.railway.app
